# ===============================================================
# COPIER CE FICHIER EN .env ET RENSEIGNER LES VALEURS
# cp .env.example .env
# ===============================================================

# ===============================
# SERVER
# ===============================
SERVER_PORT=9000
SERVER_CONTEXT_PATH=/tasksmanager
SERVER_MAX_HEADER_SIZE=65536

# ===============================
# BASE DE DONNÉES (MYSQL)
# ===============================
MYSQL_DATABASE=tasksmanager_global
MYSQL_USERNAME=root
MYSQL_PASSWORD=yourpassword

# ===============================
# JPA / HIBERNATE
# ===============================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# ===============================
# JWT SECURITY
# ===============================
JWT_SECRET=yourSuperSecretKeyMinimum32Characters
JWT_EXPIRATION_MS=86400000

# ===============================
# REDIS
# ===============================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===============================
# CACHE
# ===============================
CACHE_TTL=600000
CACHE_KEY_PREFIX=tasksmanager::

# ===============================
# CORS / CLIENT
# ===============================
CLIENT_URL=http://localhost:4200
ALLOWED_ORIGIN=http://localhost:4200

# ===============================
# FILE UPLOAD
# ===============================
MAX_FILE_SIZE=200MB
MAX_REQUEST_SIZE=200MB

# ===============================
# WEBSOCKET
# ===============================
WS_MAX_TEXT_SIZE=128MB
WS_MAX_BINARY_SIZE=128MB

# ===============================
# COMPTE ADMIN PAR DÉFAUT
# ===============================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminPassword

# ===============================
# MEDIA STORAGE
# ===============================
MEDIA_DOC_TACHE=./media/document/tache/
MEDIA_DOC_ACTIVITE=./media/document/activite/
MEDIA_DOC_PROJET=./media/document/projet/
MEDIA_COM_TACHE=./media/commentaire/tache/
MEDIA_COM_ACTIVITE=./media/commentaire/activite/
MEDIA_COM_PROJET=./media/commentaire/projet/
MEDIA_USER_PROFIL=./media/userProfil/

# ===============================
# ONLYOFFICE
# ===============================
# Option A — tu as déjà une instance OnlyOffice (lien cloud ou serveur perso) :
#   Renseigne l'URL ici et passe ONLYOFFICE_INSTALL=false
# Option B — pas d'instance OnlyOffice :
#   Laisse l'URL par défaut et passe ONLYOFFICE_INSTALL=true
#   Docker lancera automatiquement un serveur OnlyOffice sur le port 8080

ONLYOFFICE_URL=http://localhost:8080
ONLYOFFICE_INSTALL=true

# ===============================
# FRONTEND
# ===============================
API_URL=http://localhost:9000
